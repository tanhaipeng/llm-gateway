# ===================================
# LLM Gateway 环境变量配置
# ===================================

# 内置 Providers
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# 自定义 Providers (OpenAI 兼容)
# 每个自定义 provider 都可以通过环境变量配置 API key
# 格式: <PROVIDER_NAME>_API_KEY

MISTRAL_API_KEY=your_mistral_key_here
GROQ_API_KEY=your_groq_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
XAI_API_KEY=your_xai_key_here

# 更多自定义 providers...
# MY_CUSTOM_PROVIDER_API_KEY=your_custom_key_here

# ===================================
# 说明
# ===================================
# 1. 如果你只使用内置的 OpenAI 和 Anthropic，只需配置前两个变量
# 2. 使用配置文件 (config.yaml) 时，API keys 仍可以从环境变量加载
# 3. Provider 名称会被转换为大写并替换 - 为 _ 来匹配环境变量名
#    例如: "my-provider" -> "MY_PROVIDER_API_KEY"
