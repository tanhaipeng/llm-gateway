# ===================================
# LLM Gateway 环境变量配置
# ===================================

# 网关认证 API Key（可选）
# 如果设置了此变量，所有请求都需要在 Authorization header 中提供此 API key
# 格式: Authorization: Bearer YOUR_GATEWAY_API_KEY
# 注意：/health 和 /metrics 端点不需要认证
GATEWAY_API_KEY=your_gateway_api_key_here

# 内置 Providers
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...

# 自定义 Providers (OpenAI 兼容)
# 每个自定义 provider 都可以通过环境变量配置 API key
# 格式: <PROVIDER_NAME>_API_KEY

MISTRAL_API_KEY=your_mistral_key_here
GROQ_API_KEY=your_groq_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
XAI_API_KEY=your_xai_key_here

# 更多自定义 providers...
# MY_CUSTOM_PROVIDER_API_KEY=your_custom_key_here

# ===================================
# 说明
# ===================================
# 1. 如果设置了 GATEWAY_API_KEY，所有 API 请求都需要认证（/health 和 /metrics 除外）
# 2. 如果你只使用内置的 OpenAI 和 Anthropic，只需配置对应变量
# 3. 使用配置文件 (config.yaml) 时，API keys 仍可以从环境变量加载
# 4. Provider 名称会被转换为大写并替换 - 为 _ 来匹配环境变量名
#    例如: "my-provider" -> "MY_PROVIDER_API_KEY"
